{
  "name": "koromo-helper",
  "private": true,
  "workspaces": [
    "./apps/*",
    "./packages/*"
  ],
  "scripts": {
    "native": "cd apps/expo && bun run start",
    "native:prebuild": "cd apps/expo && bun run prebuild",
    "ios": "cd apps/expo && bun run ios",
    "android": "cd apps/expo && bun run android",
    "watch": "ultra -r --no-pretty --concurrency 400 watch",
    "vercel:install": "bun set version 3.5 && bun install",
    "web": "bun run build && cd apps/next && bun run next ",
    "web:extract": "DISABLE_EXTRACTION=false bun workspace next-app dev",
    "web:prod": "bun workspace next-app build",
    "web:prod:serve": "bun workspace next-app serve",
    "postinstall": "bun run check-tamagui && bun run build",
    "build": "turbo run build --filter=!next-app",
    "upgrade:tamagui": "bun up '*tamagui*'@latest '@tamagui/*'@latest",
    "upgrade:tamagui:canary": "bun up '*tamagui*'@canary '@tamagui/*'@canary",
    "check-tamagui": "tamagui check",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "resolutions": {
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-refresh": "^0.14.0",
    "react-native-svg": "15.11.2",
    "react-native-web": "~0.19.12"
  },
  "dependencies": {
    "@babel/runtime": "^7.24.6",
    "@tamagui/cli": "^1.132.8",
    "check-dependency-version-consistency": "^4.1.0",
    "eslint": "^9.3.0",
    "husky": "^9.1.6",
    "prettier": "^3.3.3",
    "turbo": "^1.13.4",
    "typescript": "~5.8.3",
    "ultra-runner": "^3.10.5",
    "vitest": "^2.1.1"
  },
  
  "engines": {
    "node": "22",
    "npm": "10.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.3"
  },
  "packageManager": "bun@1.2.18"
}
